{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=exchange_stream;Username=postgres;Password=postgres;Pooling=true;Maximum Pool Size=20"
  },
  "Exchanges": {
    "A": {
      "Uri": "ws://localhost:8001/stream",
      "InitialReconnectDelayMs": 1000,
      "MaxReconnectDelayMs": 60000
    },
    "B": {
      "Uri": "ws://localhost:8002/stream",
      "InitialReconnectDelayMs": 1000,
      "MaxReconnectDelayMs": 60000
    }
  }
}
